# ============================================
# DocHub Docker 部署环境变量配置
# 复制此文件为 .env 并修改对应值
# ============================================

# ---- 数据库配置 ----
DB_ROOT_PASSWORD=dochub123456
DB_NAME=dochub
DB_PORT=3307

# ---- Web 服务端口 ----
WEB_PORT=8090

# ---- 运行模式 (dev / prod) ----
RUNMODE=dev

# ---- 支付总开关 ----
# false = 测试模式（模拟支付成功，用于开发调试）
# true  = 真实支付模式（需要配置下方支付宝/微信参数）
PAY_ENABLE=false
PAY_COINRATE=10
PAY_SITEDOMAIN=http://localhost:8090

# ---- 支付宝配置 ----
# 申请地址: https://open.alipay.com
ALIPAY_ENABLE=false
ALIPAY_APPID=
ALIPAY_PRIVATEKEY=
ALIPAY_PUBLICKEY=
ALIPAY_GATEWAY=https://openapi.alipay.com/gateway.do

# ---- 微信支付配置 ----
# 申请地址: https://pay.weixin.qq.com
WECHAT_ENABLE=false
WECHAT_APPID=
WECHAT_MCHID=
WECHAT_APIKEY=
